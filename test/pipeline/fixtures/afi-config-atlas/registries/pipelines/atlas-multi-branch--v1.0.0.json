{
  "schema": "afi.pipeline.v1",
  "pipelineId": "atlas-multi-branch",
  "pipelineVersion": "v1.0.0",
  "description": "SECOND-STRATEGY PROOF graph (test overlay): news-early entry fanning out to a parallel news+sentiment wave, a CONDITIONAL aiMl probe BEFORE the merge, a three-parent namespace merge, and the atlas test scorer sink — a materially different topology from the official froggy composition. Lane nodes carry explicit providerInstanceRefs per FLPR-GOV D-FLPR-4 (the atlas aiMl probe plugin is a test overlay that ignores its inert reference).",
  "entry": "news-early",
  "nodes": [
    {
      "id": "news-early",
      "category": "news",
      "pluginId": "afi-analysis-news",
      "pluginVersion": "2.0.0",
      "config": {
        "windowHours": 2
      },
      "critical": false,
      "failurePolicy": "degrade",
      "providerInstanceRef": {
        "providerInstanceId": "afi-instance-reference-news-sec-edgar",
        "recordVersion": "1.0.0"
      }
    },
    {
      "id": "news",
      "category": "news",
      "pluginId": "afi-analysis-news",
      "pluginVersion": "2.0.0",
      "config": {
        "windowHours": 24
      },
      "critical": false,
      "failurePolicy": "degrade",
      "providerInstanceRef": {
        "providerInstanceId": "afi-instance-reference-news-sec-edgar",
        "recordVersion": "1.0.0"
      }
    },
    {
      "id": "sentiment",
      "category": "sentiment",
      "pluginId": "afi-analysis-sentiment",
      "pluginVersion": "2.0.0",
      "critical": false,
      "failurePolicy": "degrade",
      "providerInstanceRef": {
        "providerInstanceId": "afi-instance-reference-sentiment-cftc-cot",
        "recordVersion": "1.0.0"
      }
    },
    {
      "id": "aiml",
      "category": "aiMl",
      "pluginId": "afi-aiml-atlas-probe",
      "pluginVersion": "1.0.0",
      "critical": false,
      "failurePolicy": "degrade",
      "providerInstanceRef": {
        "providerInstanceId": "afi-instance-reference-aiml-tiny-brains",
        "recordVersion": "1.0.0"
      }
    },
    {
      "id": "merge",
      "category": "merge",
      "pluginId": "afi-merge-enriched-view",
      "pluginVersion": "1.1.0",
      "join": {
        "policy": "all",
        "merge": {
          "strategy": "namespace-by-node",
          "conflictRule": "error"
        }
      }
    },
    {
      "id": "scorer",
      "category": "scorer",
      "pluginId": "afi-scorer-atlas-probe",
      "pluginVersion": "1.0.0"
    }
  ],
  "edges": [
    {
      "from": "news-early",
      "to": "news"
    },
    {
      "from": "news-early",
      "to": "sentiment"
    },
    {
      "from": "news",
      "to": "aiml",
      "condition": {
        "eq": {
          "path": "/nodes/news/output/category",
          "value": "news"
        }
      }
    },
    {
      "from": "news",
      "to": "merge",
      "optional": true
    },
    {
      "from": "sentiment",
      "to": "merge",
      "optional": true
    },
    {
      "from": "aiml",
      "to": "merge",
      "optional": true
    },
    {
      "from": "merge",
      "to": "scorer"
    }
  ]
}
