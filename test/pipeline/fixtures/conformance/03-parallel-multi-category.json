{
  "schema": "afi.pipeline.v1",
  "pipelineId": "proof-parallel-multi-category",
  "pipelineVersion": "v1.0.0",
  "description": "CONFORMANCE FIXTURE (non-production): sentiment and news branches derived concurrently after the technical entry (concurrency from dependency structure, never assumed), joined deterministically before the scorer.",
  "entry": "technical",
  "nodes": [
    {
      "id": "technical",
      "category": "technical",
      "pluginId": "afi-analysis-technical",
      "pluginVersion": "1.0.0"
    },
    {
      "id": "sentiment",
      "category": "sentiment",
      "pluginId": "afi-analysis-sentiment",
      "pluginVersion": "1.0.0"
    },
    {
      "id": "news",
      "category": "news",
      "pluginId": "afi-analysis-news",
      "pluginVersion": "1.0.0",
      "config": { "windowHours": 12 }
    },
    {
      "id": "merge",
      "category": "merge",
      "pluginId": "afi-merge-enriched-view",
      "pluginVersion": "1.0.0",
      "join": {
        "policy": "all",
        "merge": { "strategy": "namespace-by-node", "conflictRule": "error" }
      }
    },
    {
      "id": "scorer",
      "category": "scorer",
      "pluginId": "afi-scorer-froggy-trend-pullback",
      "pluginVersion": "1.0.0"
    }
  ],
  "edges": [
    { "from": "technical", "to": "sentiment" },
    { "from": "technical", "to": "news" },
    { "from": "technical", "to": "merge" },
    { "from": "sentiment", "to": "merge" },
    { "from": "news", "to": "merge" },
    { "from": "merge", "to": "scorer" }
  ]
}
