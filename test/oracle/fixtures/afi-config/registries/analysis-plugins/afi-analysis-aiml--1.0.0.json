{
  "schema": "afi.analysis-plugin.v1",
  "pluginId": "afi-analysis-aiml",
  "pluginVersion": "1.0.0",
  "implementationVersion": "1.0.0",
  "category": "aiMl",
  "description": "Official AI/ML augmentation plugin manifest: augments the merged enriched view with model-derived features from the tiny-brains service. External service call — NOT deterministic.",
  "inputSchemaRef": "afi.enrichment.enriched-view.v1",
  "outputSchemaRef": "afi.enrichment.aiml.v1",
  "deterministic": false,
  "capabilities": ["service:tiny-brains"],
  "defaultTimeoutMs": 15000,
  "defaultRetryPolicy": {
    "maxRetries": 1,
    "retryDelayMs": 250,
    "backoff": "exponential"
  },
  "permittedFailurePolicies": ["abort", "degrade"],
  "paramsSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {}
  },
  "multiInstance": true,
  "mayFeedScorer": true
}
