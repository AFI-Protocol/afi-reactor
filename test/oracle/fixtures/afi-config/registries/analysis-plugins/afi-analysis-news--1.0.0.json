{
  "schema": "afi.analysis-plugin.v1",
  "pluginId": "afi-analysis-news",
  "pluginVersion": "1.0.0",
  "implementationVersion": "1.0.0",
  "category": "news",
  "description": "Official market-news plugin manifest: extracts recent-news features for the signal's asset from the NewsData provider over a configurable window. External provider call — NOT deterministic; requires the NEWSDATA_API_KEY secret class in the operator environment.",
  "inputSchemaRef": "afi.usignal.v1.1",
  "outputSchemaRef": "afi.enrichment.news.v1",
  "deterministic": false,
  "capabilities": ["provider:newsdata", "secret:NEWSDATA_API_KEY"],
  "defaultTimeoutMs": 10000,
  "defaultRetryPolicy": {
    "maxRetries": 2,
    "retryDelayMs": 500,
    "backoff": "fixed"
  },
  "permittedFailurePolicies": ["abort", "degrade"],
  "paramsSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "windowHours": {
        "type": "integer",
        "minimum": 1,
        "maximum": 168,
        "description": "Look-back window (hours) for news retrieval."
      }
    }
  },
  "multiInstance": true,
  "mayFeedScorer": true
}
