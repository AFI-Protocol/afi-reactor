# AFI Reactor Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - it's in .gitignore

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Port for the AFI Reactor HTTP server (default: 8080)
AFI_REACTOR_PORT=8080

# Optional shared secret for webhook authentication
# If set, TradingView webhooks must include this secret in their payload
# WEBHOOK_SHARED_SECRET=your-secret-here

# ============================================================================
# CANONICAL EVIDENCE STORE (afi-infra) — the ONLY reactor persistence path
# ============================================================================
#
# Scored signals persist through the packaged afi-infra canonical evidence store
# (afi.scored-signal-evidence.v3) on real MongoDB. The legacy Reactor-owned
# scored-signal collection + its AFI_MONGO_* config have been removed.
#
# Required in production/live runtime:
# AFI_EVIDENCE_MONGODB_URI=mongodb://<host>:27017/?replicaSet=rs0
# Optional overrides: AFI_EVIDENCE_DB_NAME, AFI_EVIDENCE_COLLECTION,
#                     AFI_EVIDENCE_HISTORY_COLLECTION

# ============================================================================
# PRICE FEED CONFIGURATION
# ============================================================================

# Price feed source: 'demo' | 'blofin' | 'coinbase'
# AFI_PRICE_FEED_SOURCE=demo

# BloFin API credentials (if using blofin price feed)
# BLOFIN_API_KEY=your-api-key
# BLOFIN_API_SECRET=your-api-secret

# Coinbase API credentials (if using coinbase price feed)
# COINBASE_API_KEY=your-api-key
# COINBASE_API_SECRET=your-api-secret

# ============================================================================
# EXTERNAL SERVICES (Optional)
# ============================================================================

# NewsData.io BYOK key — the env-backed reference SecretResolver's backend for
# the credential-newsdata-reference CredentialRef (header-carried at invocation;
# absent → the BYOK news instance fails closed; the keyless SEC-EDGAR reference
# instance needs no key)
# NEWSDATA_API_KEY=your-newsdata-api-key

# Coinalyze BYOK key — backend for the credential-coinalyze-reference
# CredentialRef (header-carried; absent → the BYOK sentiment instance fails
# closed; the keyless CFTC-COT reference instance needs no key)
# COINALYZE_API_KEY=your-coinalyze-api-key

# Tiny Brains self-hosted service URL (pattern + aiMl reference lanes)
# TINY_BRAINS_URL=http://localhost:8090

# ============================================================================
# DEVELOPMENT / DEBUGGING
# ============================================================================

# Enable verbose logging
# DEBUG=afi:*

# Node environment
# NODE_ENV=development
